# ── LLM Provider (pick ONE, all free) ─────────────────────────────────────────
#
#  "fallback" → Pure rule-based logic. Zero API key needed. Works offline.
#               This is the default — the app is fully functional with no setup.
#
#  "ollama"   → 100% local & free forever. No API key, no internet required.
#               Setup: https://ollama.com → install → run: ollama pull llama3.2
#
#  "groq"     → Free cloud API. Very fast. No credit card needed.
#               Get key: https://console.groq.com  (free account)
#
#  "gemini"   → Google Gemini free tier (gemini-1.5-flash). Generous limits.
#               Get key: https://aistudio.google.com/app/apikey (free)
#
LLM_PROVIDER=fallback

# ── Ollama settings (only if LLM_PROVIDER=ollama) ─────────────────────────────
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434

# ── Groq settings (only if LLM_PROVIDER=groq) ─────────────────────────────────
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama3-8b-8192

# ── Gemini settings (only if LLM_PROVIDER=gemini) ─────────────────────────────
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── REMOVED (no longer needed) ────────────────────────────────────────────────
# ANTHROPIC_API_KEY — Claude is no longer used. System is fully free.
